{
  "name": "vue-elven",
  "version": "1.0.0",
  "description": "Vue3 + TypeScript + Naive UI 管理系统",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "preview": "vite preview",
    "lint": "pnpm lint:eslint && pnpm lint:prettier && pnpm lint:stylelint",
    "lint:eslint": "eslint --cache --max-warnings 0 \"src/**/*.{vue,ts,tsx}\"",
    "lint:eslint:fix": "eslint --cache --max-warnings 0 \"src/**/*.{vue,ts,tsx}\" --fix",
    "lint:prettier": "prettier --write \"**/*.{js,ts,json,tsx,css,less,scss,vue,html,md}\" --ignore \"node_modules/**\" --ignore \"dist/**\"",
    "lint:stylelint": "stylelint --cache --fix \"**/*.{vue,less,postcss,css,scss}\" --cache --cache-location node_modules/.cache/stylelint/",
    "type-check": "vue-tsc --noEmit",
    "prepare": "husky",
    "commitlint": "commitlint --last --verbose"
  },
  "dependencies": {
    "@vueuse/core": "^14.1.0",
    "axios": "^1.13.2",
    "cropperjs": "^2.1.0",
    "crypto-js": "^4.2.0",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "vue": "^3.5.26",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "@eslint/js": "^9.39.2",
    "@iconify-icons/icon-park-outline": "^1.2.11",
    "@iconify/vue": "^5.0.0",
    "@types/crypto-js": "^4.2.2",
    "@types/node": "^25.0.7",
    "@vitejs/plugin-vue": "^6.0.3",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-vue": "^10.6.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "naive-ui": "^2.43.2",
    "postcss": "^8.5.6",
    "postcss-html": "^1.8.0",
    "postcss-scss": "^4.0.9",
    "prettier": "^3.7.4",
    "rollup-plugin-visualizer": "^6.0.5",
    "sass": "^1.97.2",
    "stylelint": "^16.26.1",
    "stylelint-config-html": "^1.1.0",
    "stylelint-config-recess-order": "^7.4.0",
    "stylelint-config-recommended-scss": "^16.0.2",
    "stylelint-config-recommended-vue": "^1.6.1",
    "stylelint-config-standard": "^39.0.1",
    "stylelint-config-standard-scss": "^16.0.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.53.0",
    "vite": "^7.3.1",
    "vite-plugin-compression": "^0.5.1",
    "vite-plugin-html": "^3.2.2",
    "vite-plugin-mock": "^3.0.2",
    "vite-svg-loader": "^5.1.0",
    "vue-eslint-parser": "^10.2.0",
    "vue-tsc": "^3.2.2"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/xbaof/vue-elven"
  },
  "engines": {
    "node": "^20.19.0 || >=22.13.0",
    "pnpm": ">=9"
  },
  "keywords": [
    "vue3",
    "typescript",
    "naive-ui",
    "vite",
    "pinia",
    "vue-router",
    "admin",
    "dashboard"
  ],
  "author": "Vue Elven Team",
  "license": "MIT",
  "lint-staged": {
    "*.{js,ts,tsx,vue}": [
      "eslint --max-warnings 0 --fix"
    ],
    "*.{css,scss,less,postcss,vue}": [
      "stylelint --fix"
    ],
    "*.{json,md,html}": [
      "prettier --write"
    ]
  }
}
